# ================================================================
# FALKON PRO — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env
# ================================================================

# ── Database (Neon PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.neon.tech/neondb?sslmode=require

# ── Telegram API (from my.telegram.org) ───────────────────────
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Admin Panel (keep this SECRET) ───────────────────────────
ADMIN_SECRET_KEY=change-this-to-a-very-strong-secret-key-min-32-chars

# ── Optional: Data directory for legacy file storage ──────────
# DATA_DIR=/opt/falkon/data
