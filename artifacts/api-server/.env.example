# Falkon API production environment
NODE_ENV=production
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Admin authentication. Generate independent random values and keep them in a secret manager.
ADMIN_SECRET_KEY=replace-with-a-long-random-admin-password
ADMIN_TOKEN_KEY=replace-with-at-least-32-random-characters
ADMIN_SESSION_TTL_SECONDS=28800

# Exactly 32 bytes, encoded as 64 hexadecimal characters or Base64.
# Generate hex with: openssl rand -hex 32
DATA_ENCRYPTION_KEY=replace-with-64-hex-characters

# Telegram application credentials
TELEGRAM_API_ID=replace-with-telegram-api-id
TELEGRAM_API_HASH=replace-with-telegram-api-hash

# Browser origins only. Capacitor local origins and the configured server origin are added internally.
CORS_ALLOWED_ORIGINS=https://dashboard.example.com

# Optional operational tuning
LOG_LEVEL=info
DATA_DIR=/var/lib/falkon
POOL_MAX_CONCURRENCY=10
POOL_MAX_PER_ACCOUNT=2
