{
  "expo": {
    "name": "FALKON PRO",
    "slug": "falkon-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "falkonpro",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#030712"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.falkonpro.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is not required",
        "NSPhotoLibraryUsageDescription": "Photo library access is not required"
      }
    },
    "android": {
      "package": "com.falkonpro.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#030712"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "allowBackup": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://falkonpro.app/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow FALKON PRO to access your Face ID biometric data."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "falkon-pro-001"
      }
    }
  }
}
